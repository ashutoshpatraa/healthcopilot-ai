# ============================================================
# HealthCopilot AI — .gitignore
# ============================================================

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# ─── Environment & Secrets ──────────────────────────────────
# NEVER commit secrets or credentials
.env
.env.*
!.env.example
backend/.env
frontend/.env
kaggle.json
*.pem
*.key
*.secret
*.credential

# ─── Databases ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal

# ─── ML Artifacts ───────────────────────────────────────────
# Trained models and datasets are generated locally
# Run: python backend/scripts/train.py
datasets/
trained_models/
*.pkl
*.h5
*.pt
*.pth
*.onnx
*.joblib

# ─── Testing & Coverage ─────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml

# ─── Node / Frontend ────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.vite/
.turbo/
.cache/

# ─── IDE & Editor ───────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.history/

# ─── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Uploads & Generated Files ──────────────────────────────
uploads/
backend/uploads/
*.log
logs/
temp/
tmp/
*.tmp
*.bak
*.backup

# ─── Build Artifacts ────────────────────────────────────────
build/
*.egg-info/
.eggs/
